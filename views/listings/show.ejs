<% layout("layouts/boilerplate.ejs") -%>

<script>
    const mapToken="<%=process.env.MAP_TOKEN%>";
    const listing=<%- JSON.stringify(listing) %>;
</script>

<div class="row justify-content-center mt-3">

    <div class="col-lg-8">

        <h2><%= listing.title %></h2>

        <div class="card listing-card mt-3">
            <img
                src="<%= listing.image.url %>"
                class="card-img-top show-img"
                alt="listing image"
            >

            <div class="card-body">

                <p><b>Owned By:</b> <%= listing.owner.username %></p>

                <p><%= listing.description %></p>

                <p>&#8377; <%= listing.price.toLocaleString("en-IN") %></p>

                <p><%= listing.location %></p>

                <p><%= listing.country %></p>

            </div>

        </div>

        <% if(currUser && currUser._id.equals(listing.owner._id)){ %>

        <div class="btns mb-4">

            <a
                href="/listings/<%= listing._id %>/edit"
                class="btn btn-dark btn-edit me-2"
            >
                Edit
            </a>

            <form
                method="POST"
                action="/listings/<%= listing._id %>?_method=DELETE"
            >

                <button class="btn btn-dark">
                    Delete
                </button>

            </form>

        </div>

        <% } %>

        <hr>

        <% if(currUser){ %>

        <h4>Leave A Review</h4>

        <form
            method="POST"
            action="/listings/<%= listing._id %>/reviews"
            novalidate
            class="needs-validation"
        >

            <div class="mb-3">

                <label class="form-label">
                    Rating
                </label>

                <fieldset class="starability-slot">

                    <input type="radio" id="no-rate"
                        class="input-no-rate"
                        name="review[rating]"
                        value="1"
                        checked>

                    <input type="radio" id="first-rate1"
                        name="review[rating]"
                        value="1">

                    <label for="first-rate1">1 star</label>

                    <input type="radio"
                        id="first-rate2"
                        name="review[rating]"
                        value="2">

                    <label for="first-rate2">2 stars</label>

                    <input type="radio"
                        id="first-rate3"
                        name="review[rating]"
                        value="3">

                    <label for="first-rate3">3 stars</label>

                    <input type="radio"
                        id="first-rate4"
                        name="review[rating]"
                        value="4">

                    <label for="first-rate4">4 stars</label>

                    <input type="radio"
                        id="first-rate5"
                        name="review[rating]"
                        value="5">

                    <label for="first-rate5">5 stars</label>

                </fieldset>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Comments
                </label>

                <textarea
                    class="form-control"
                    rows="5"
                    name="review[comment]"
                    required
                ></textarea>

                <div class="invalid-feedback">
                    Please add a comment.
                </div>

            </div>

            <button class="btn btn-outline-dark">
                Submit
            </button>

        </form>

        <hr>

        <% } %>

        <% if(listing.reviews.length>0){ %>

        <h4 class="mb-3">
            All Reviews
        </h4>

        <div class="row">

            <% for(review of listing.reviews){ %>

            <div class="col-md-6 mb-3">

                <div class="card h-100">

                    <div class="card-body">

                        <h5>
                            @<%= review.author.username %>
                        </h5>

                        <p
                            class="starability-result"
                            data-rating="<%= review.rating %>"
                        ></p>

                        <p>
                            <%= review.comment %>
                        </p>

                        <form
                            method="POST"
                            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                        >

                            <button class="btn btn-dark btn-sm">
                                Delete
                            </button>

                        </form>

                    </div>

                </div>

            </div>

            <% } %>

        </div>

        <% } %>

        <hr>

        <h3 class="mb-3">
            Where you'll be
        </h3>

        <div id="map"></div>

    </div>

</div>

<script src="/js/map.js"></script>